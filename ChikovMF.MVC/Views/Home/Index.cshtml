@using ChikovMF.MVC.Models.Form.Home;
@model MessageMeFormModel
@{
    ViewData["Title"] = "Главная страница";
}

<div class="container">
    <div class="row">
        <div class="col-sm-3 d-sm-block d-none">
            <img src="/img/home/me.png" class="img-fluid border" alt="Мое фото">
